# macOS
.DS_Store
**/.DS_Store

# Xcode build output
build/
build-for-testing/
DerivedData/
xcuserdata/
*.xcuserdatad/
*.xcuserstate

bin/
# gstack-ios skill report cache
gstack-ios/.cache/

# Python (agent-a, agent-b)
__pycache__/
*.pyc
.venv/
.uv-cache/
.pytest_cache/
*.duckdb
*.duckdb.wal
infra/data/*.duckdb
infra/data/*.duckdb.wal
infra/data/acks_out/
infra/data/events_log/
infra/data/test_*/
infra/pilot/identity.json
.env

# Per-agent gbrain runtimes (PGLite blobs + macOS bun cache that ends up
# inside the agent's HOME because we set HOME=<gbrain-*-home> for the CLI).
# These are LOCAL state, never commit.
infra/data/gbrain-*/
infra/data/gbrain-*-home/
*.pglite/
**/.gbrain/
**/Library/Caches/
**/Library/Logs/
**/Library/Preferences/

# Secrets — never commit
infra/secrets/
infra/docker/pilot-bin/

# OpenClaw per-agent workspace state (the runtime files; the manifests
# under .openclaw/{name}-workspace/IDENTITY.md etc. live there too — if
# you want those committed, narrow this rule instead of dropping it).
.openclaw/

# Pilot per-container state
infra/pilot-data-*/

# Test inboxes / output drops
infra/data/test_inbox/
infra/data/test_var/

# Local OAuth tokens (in case anything escapes infra/secrets/)
**/google-calendar-token.json
**/google-tokens.json
